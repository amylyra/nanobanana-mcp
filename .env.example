# Required — Google AI API key (either name works)
GEMINI_API_KEY=your-key-here
# GOOGLE_AI_API_KEY=your-key-here   # alternative name

# Optional — cloud storage for URL output instead of base64 (pick one)
# S3_BUCKET=claude-image-cache
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
#
# GCS_BUCKET=my-nanobanana-images

# Optional — server config
# HOST=0.0.0.0
# PORT=8080
# DEFAULT_OUTPUT=cloud   # "base64" (default), "cloud", "s3", or "gcs"

# Optional — public URL for the server (used in elicitation upload links)
# Set this on Cloud Run to your service URL, e.g. https://nanobanana-xxx.run.app
# PUBLIC_URL=https://your-service.run.app
