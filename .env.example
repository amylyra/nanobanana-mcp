# Required — Google AI API key (either name works)
GEMINI_API_KEY=your-key-here
# GOOGLE_AI_API_KEY=your-key-here   # alternative name

# Optional — S3 catch-all storage (images auto-uploaded in background when set)
# S3_BUCKET=claude-image-cache
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
#
# Optional — GCS storage (used if S3_BUCKET not set)
# GCS_BUCKET=my-nanobanana-images

# Optional — server config
# HOST=0.0.0.0
# PORT=8080

# Required on Cloud Run — public URL for image URLs and upload links
# Without this, all image URLs will use localhost which breaks in production.
# PUBLIC_URL=https://your-service.run.app
